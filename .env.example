GROQ_API_KEY=your-groq-api-key-here

# Optional override. Default is llama-3.1-8b-instant on Groq (free
# tier: 14.4K req/day + 500K tok/day — plenty for tests and demos).
# Swap to llama-3.3-70b-versatile for richer responses (free tier
# caps at 1000 req/day + 100K tok/day on that model).
# LLM_MODEL=llama-3.1-8b-instant

# Optional: throttle below Groq's 30 req/min ceiling. Default is 1s
# between calls (~60 RPM headroom). Set to 0 on paid tiers.
# LLM_MIN_INTERVAL=1.0
